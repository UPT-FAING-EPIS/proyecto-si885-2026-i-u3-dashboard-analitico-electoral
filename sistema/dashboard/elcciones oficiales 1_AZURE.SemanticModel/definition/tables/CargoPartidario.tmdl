	column 'Cargo Estandarizado' =
			
			IF(
			    'CargoPartidario'[TipoCargo] = "ELECCION_POPULAR",
			    SWITCH(
			        TRUE(),
			        CONTAINSSTRING('CargoPartidario'[Cargo], "GOBERN"), "GOBERNADOR(A) REGIONAL",
			        CONTAINSSTRING('CargoPartidario'[Cargo], "ALCAL"), "ALCALDE(SA) PROVINCIAL O DISTRITAL",
			        CONTAINSSTRING('CargoPartidario'[Cargo], "REGID"), "REGIDOR(A) PROVINCIAL O DISTRITAL",
			        CONTAINSSTRING('CargoPartidario'[Cargo], "CONRES"), "CONGRESISTA",
			        CONTAINSSTRING('CargoPartidario'[Cargo], "DIPUTADO"), "DIPUTADO(A)",
			        'CargoPartidario'[Cargo]-- Si no cumple ninguna, deja el nombre original
			    ),
			    'CargoPartidario'[Cargo] -- Si no es ELECCION_POPULAR, deja el nombre original
			)
		lineageTag: 3443a710-7a6e-471a-bfa2-3edf687c6451
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Fecha Inicio DT' = DATE(CargoPartidario[AnioInicio], 1, 1)
		formatString: Short Date
		lineageTag: 1a203bd5-528d-4a0a-be00-28a03c613b5a
