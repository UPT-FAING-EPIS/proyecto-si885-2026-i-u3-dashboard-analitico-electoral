		annotation UnderlyingDateTimeDataType = Date

	column 'Fecha Fin Corregida' = ```
			
			IF(
			    ISBLANK(CargoPartidario[AnioFin]), 
			    TODAY(), 
			    DATE(CargoPartidario[AnioFin], 1, 1)
			)
			```
		formatString: Short Date
