	measure '% Posgrado Concluido' = ```
			
			VAR CandidatosConcluidos = 
			    CALCULATE(
			        DISTINCTCOUNT('Posgrado'[IdCandidato]), 
			        'Posgrado'[Concluido] = TRUE()
			    )
			VAR TotalCandidatos = 
			    DISTINCTCOUNT('Candidato'[IdCandidato])
			
			RETURN 
			    DIVIDE(CandidatosConcluidos, TotalCandidatos, 0)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 2b5309b2-ca94-41ad-a412-b7ef8192bd28

