	measure 'Estado Posgrado Medida' = ```
			
			VAR PosgradosConcluidos = 
			    COUNTROWS(
			        FILTER(
			            RELATEDTABLE('Posgrado'), 
			            'Posgrado'[Concluido] = TRUE()
			        )
			    )
			RETURN
			    IF(
			        ISBLANK(PosgradosConcluidos) || PosgradosConcluidos = 0, 
			        "Sin Posgrado", 
			        "Con Posgrado"
			    )
			```
