	measure 'Propuesta Corta Candidato A' =
			
			VAR IdA = SELECTEDVALUE('Selector Candidato A'[IdCandidatoWeb])
			RETURN
			    IF(
			        ISBLANK(IdA),
			        "Elige candidato A",
			        CONCATENATEX(
			            CALCULATETABLE(
			                VALUES(Neocities_PropuestasDetalle[PropuestaCorta]),
			                Neocities_PropuestasDetalle[IdCandidatoWeb] = IdA
			            ),
			            Neocities_PropuestasDetalle[PropuestaCorta],
			            UNICHAR(10)
			        )
			    )
		lineageTag: 8d4eea2a-d93a-4765-8f2f-052535729d7f

	measure 'Propuesta Corta Candidato B' =
			
			VAR IdB = SELECTEDVALUE('Selector Candidato B'[IdCandidatoWeb])
			RETURN
			    IF(
			        ISBLANK(IdB),
			        "Elige candidato B",
			        CONCATENATEX(
			            CALCULATETABLE(
			                VALUES(Neocities_PropuestasDetalle[PropuestaCorta]),
			                Neocities_PropuestasDetalle[IdCandidatoWeb] = IdB
			            ),
			            Neocities_PropuestasDetalle[PropuestaCorta],
			            UNICHAR(10)
			        )
			    )
		lineageTag: cc3eeac8-2816-4f62-929d-a2a296d62547

	measure 'Detalle Propuesta Candidato A' =
			
			VAR IdA = SELECTEDVALUE('Selector Candidato A'[IdCandidatoWeb])
			RETURN
			    IF(
			        NOT ISINSCOPE(Neocities_PropuestasDetalle[Tema]),
			        BLANK(),
			        IF(
			            ISBLANK(IdA),
			            "Elige candidato A",
			            CONCATENATEX(
			                CALCULATETABLE(
			                    VALUES(Neocities_PropuestasDetalle[PropuestaDetalle]),
			                    Neocities_PropuestasDetalle[IdCandidatoWeb] = IdA
			                ),
			                Neocities_PropuestasDetalle[PropuestaDetalle],
			                UNICHAR(10)
			            )
			        )
			    )
		lineageTag: d9d81870-32bb-4076-bbd1-c78b854dc7af

	measure 'Detalle Propuesta Candidato B' =
			
