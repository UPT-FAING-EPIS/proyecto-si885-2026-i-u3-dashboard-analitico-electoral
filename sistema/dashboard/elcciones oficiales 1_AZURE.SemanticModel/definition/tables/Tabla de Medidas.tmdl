table 'Tabla de Medidas'
	lineageTag: d56cbb95-9843-4f1b-b7ba-d528cc9d86e7

	measure Edad = DATEDIFF(SELECTEDVALUE(Candidato[FechaNacimiento]), TODAY(), YEAR)
		formatString: 0
		lineageTag: ba377471-8339-4793-9a89-4f7ea6e08efc

	measure 'Edad Promedio' = AVERAGEX(Candidato, DATEDIFF(Candidato[FechaNacimiento], TODAY(), YEAR))
		lineageTag: f3e0918e-5ad7-42e2-80da-0b13acf12d26

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% por Sexo' = DIVIDE(COUNT(Candidato[IdCandidato]), CALCULATE(COUNT(Candidato[IdCandidato]), ALL(Candidato[Sexo])))
		lineageTag: 5dfbd288-8335-4658-b8b7-c1375ca05c12

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Maximo Nivel Alcanzado' = ```
			
			VAR CandidatoID = SELECTEDVALUE(Candidato[IdCandidato])
			VAR TieneDoc = COUNTROWS(FILTER(Posgrado, Posgrado[IdCandidato] = CandidatoID && CONTAINSSTRING(Posgrado[Grado], "DOCTOR")))
			VAR TieneMae = COUNTROWS(FILTER(Posgrado, Posgrado[IdCandidato] = CandidatoID && (CONTAINSSTRING(Posgrado[Grado], "MAESTR") || CONTAINSSTRING(Posgrado[Grado], "MAGISTER"))))
			VAR TieneUni = COUNTROWS(FILTER(EducacionUniversitaria, EducacionUniversitaria[IdCandidato] = CandidatoID && EducacionUniversitaria[Concluido] = 1))
			VAR TieneTec = COUNTROWS(FILTER(EstudiosTecnicos, EstudiosTecnicos[IdCandidato] = CandidatoID))
			RETURN 
			SWITCH(TRUE(),
			    TieneDoc > 0, "Doctorado",
			    TieneMae > 0, "Maestría",
			    TieneUni > 0, "Universitario",
			    TieneTec > 0, "Técnico",
			    "Educación Básica"
			)
			```
		formatString: 0
		lineageTag: 81cd418b-dd08-4971-a84f-fec5a8f9ea56

