	column 'Nombre Grado' =
			
			VAR TextoLimpio = UPPER(TRIM('Posgrado'[Grado]))
			RETURN
			SWITCH(
			    TRUE(),
			    'Posgrado'[IdPosgrado] = 43, "MAESTRÍA",
			    CONTAINSSTRING(TextoLimpio, "DOCT"), "DOCTORADO",
			    CONTAINSSTRING(TextoLimpio, "MAEST"), "MAESTRÍA",
			    CONTAINSSTRING(TextoLimpio, "ESPECIALIZA"), "ESPECIALIZACION",
			    ISBLANK('Posgrado'[Grado]) || 'Posgrado'[Grado] = "" || TextoLimpio = " ", "NO ESPECIFICADO",
			    "OTRO"
			)
		lineageTag: d1461a76-6b10-4546-9310-4838c2c14f6a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Realizo Posgrado' = ```
			
			IF(
			    COUNTROWS(
			        FILTER(
			            RELATEDTABLE('Posgrado'), 
			            'Posgrado'[Concluido] = TRUE()
			        )
			    ) > 0, 
			    "REALIZO POSGRADO", 
			    "NO REGISTRA"
			)
			```
		lineageTag: f99bb9b9-8494-4a98-8d51-3e7dbb7f67b1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

